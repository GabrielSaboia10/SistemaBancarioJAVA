generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENTE
}

model Pessoa {
  id        Int             @id @default(autoincrement())
  cpf       String          @unique @db.VarChar(14)
  nome      String          @db.VarChar(40)
  idade     Int
  contas    ContaBancaria[]
  usuario   Usuario?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Usuario {
  id        Int      @id @default(autoincrement())
  cpf       String   @unique @db.VarChar(14)
  senha     String
  role      Role     @default(CLIENTE)
  pessoaId  Int?     @unique
  pessoa    Pessoa?  @relation(fields: [pessoaId], references: [id])
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgenciaBancaria {
  id        Int             @id @default(autoincrement())
  numero    Int             @unique
  endereco  String          @db.VarChar(100)
  cidade    String          @db.VarChar(25)
  contas    ContaBancaria[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ContaBancaria {
  id                   Int             @id @default(autoincrement())
  numContaCorrente     Int             @unique
  limiteChequeEspecial Float
  saldo                Float
  correntista          Pessoa          @relation(fields: [pessoaId], references: [id])
  pessoaId             Int
  agencia              AgenciaBancaria @relation(fields: [agenciaId], references: [id])
  agenciaId            Int
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}
